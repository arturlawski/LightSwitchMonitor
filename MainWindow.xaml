<Window x:Class="LightSwitchMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LightSwitchMonitor"
        mc:Ignorable="d"
        Title="LightSwitch Monitor"
        Height="260"
        Width="420"
        MinHeight="240"
        MinWidth="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="LightSwitch Monitor"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Ekrany bez kursora sa delikatnie przyciemniane."
                       Margin="0,6,0,0"
                       Foreground="#666666"
                       TextWrapping="Wrap" />
        </StackPanel>

        <CheckBox x:Name="EnabledCheckBox"
                  Grid.Row="2"
                  Content="Wlacz przyciemnianie"
                  FontSize="14"
                  Checked="EnabledCheckBox_OnChecked"
                  Unchecked="EnabledCheckBox_OnChecked" />

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock Text="Poziom przyciemnienia"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="DimLevelTextBlock"
                           DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           FontSize="14"
                           Foreground="#555555" />
            </DockPanel>

            <Slider x:Name="DimLevelSlider"
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Minimum="5"
                    Maximum="85"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="DimLevelSlider_OnValueChanged" />
        </Grid>

        <TextBlock Grid.Row="6"
                   Text="Okno mozesz zamknac krzyzykiem. Aplikacja zostanie w trayu."
                   Foreground="#777777"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
